# 这是 .env.cli 的模板。**仅当你的网络/VPN 走不通 Supabase 默认 IPv6 直连时才需要配**。
#
# 怎么判断要不要配：
#   不配，直接跑 `make list`。
#   - 如果秒返回 migration 表 → 你网络 OK，不需要 .env.cli
#   - 如果报 "socket is not connected" / "no route to host" / TLS error 类
#     → 你 IPv6 走不通，需要走 IPv4 pooler，按下面步骤配
#
# 配置步骤：
# 1. 复制本文件为 .env.cli（已 gitignore，不会进 git）
# 2. 去 Supabase Dashboard，右上角点 Connect 按钮
# 3. 选 Session pooler tab，复制 URI
# 4. 把里面的 [YOUR-PASSWORD] 替换成你的数据库密码（建项目时设的，
#    忘了去 Settings → Database → Reset database password）
# 5. 粘到下面的引号里替换
#
# 配好后，make list / push / diff / pull / repair 会自动用这个 URL。

export SUPABASE_DB_URL="postgresql://postgres.<your-project-ref>:<your-password>@aws-X-<region>.pooler.supabase.com:5432/postgres"
